{
  "schemaVersion": 1,
  "id": "ctnhchangelog",
  "version": "${version}",
  "name": "CTNH Changelog",
  "description": "Changelog viewer for Create: New Horizon modpack.",
  "authors": ["CTNH Team", "FanZiyun"],
  "contact": {},
  "license": "LGPLv3",
  "icon": "assets/ctnhchangelog/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.mmyddd.mcmod.changelog.CTNHChangelog"
    ],
    "modmenu": [
      "com.mmyddd.mcmod.changelog.ModMenuIntegration"
    ]

  },
  "mixins": [
    "ctnhchangelog.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": "*",
    "java": "*",
    "modmenu": "*"
  },
  "custom": {
    "modmenu:api": true
  }
}